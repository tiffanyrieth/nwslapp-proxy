#!/bin/sh
#
# pre-push — guard the default branch (main) against destructive pushes.
#
# Blocks two accidents outright:
#   • DELETING main on the remote
#   • FORCE-PUSHING main (a non-fast-forward push that rewrites history)
# A normal (fast-forward) push to main is allowed but warns, since the
# preferred path is a feature branch + PR.
#
# git feeds this hook one line per ref being pushed, on stdin:
#     <local ref> <local oid> <remote ref> <remote oid>
# For a deletion, <local oid> is all zeros. For a brand-new ref, <remote oid>
# is all zeros.
#
# Local guardrail, NOT security: bypass on purpose with `git push --no-verify`.
#

protected="main"
zero="0000000000000000000000000000000000000000"
status=0

while read -r local_ref local_oid remote_ref remote_oid; do
    [ "$remote_ref" = "refs/heads/$protected" ] || continue

    if [ "$local_oid" = "$zero" ]; then
        echo "" >&2
        echo "✋ Refusing to DELETE '$protected' on the remote." >&2
        echo "   (To override on purpose: git push --no-verify)" >&2
        echo "" >&2
        status=1
    elif [ "$remote_oid" != "$zero" ] && \
         ! git merge-base --is-ancestor "$remote_oid" "$local_oid" 2>/dev/null; then
        echo "" >&2
        echo "✋ Refusing to FORCE-PUSH '$protected' (non-fast-forward)." >&2
        echo "   This would rewrite published history." >&2
        echo "   (To override on purpose: git push --no-verify)" >&2
        echo "" >&2
        status=1
    else
        echo "⚠️  Pushing directly to '$protected' — prefer a feature branch + PR." >&2
    fi
done

exit $status
