{
	"name": "nwslapp-proxy",
	"main": "src/index.ts",
	"compatibility_date": "2025-06-01",
	"observability": {
		"enabled": true,
	},
	// Caches one Claude Haiku verdict per Feed post (bsky:{uri}), ~7d TTL — backs the
	// relevance/no-hot-takes filter so a post is tagged once, ever (Step 2). Also holds
	// the B3b social-card snapshot (key "social-cards-v1"), refreshed by the cron below.
	"kv_namespaces": [
		{
			"binding": "FEED_TAGS",
			"id": "3c1372c0f8174cdcb3e2e52ca5de14ad",
		},
	],
	// Per-IP throttle for the two UNAUTHENTICATED ingest endpoints (POST /telemetry, /analytics) — the
	// only anonymous writers. Without a cap, a flood of /telemetry POSTs (one KV write each) could
	// exhaust the account-wide KV daily write budget and starve the watcher's live-match state on a
	// game day (pre-launch security pass). Native binding = FREE, does NOT consume KV. Keyed per
	// bucket+IP in code (overIngestLimit); `period` must be 10 or 60. namespace_id is an arbitrary
	// per-worker id. Fails OPEN in code if absent, so this can deploy independently.
	"ratelimits": [
		{
			"name": "INGEST_LIMITER",
			"namespace_id": "1001",
			"simple": { "limit": 20, "period": 60 },
		},
	],
	// B3b — Instagram scrape → KV social snapshot, EVERY OTHER DAY at 12:00 UTC (~7am ET).
	// Decoupled from user requests. LOAD-BALANCED (2026-07-05): clubs via Apify (~192
	// items/run ≈ $0.86/mo, inside the free $5) + players via Bright Data (async trigger →
	// /brightdata-webhook; 34×6 ≈ 204 records/run ≈ 3,060/mo, inside the free 5k/mo).
	// Flip to daily ("0 12 * * *") only after re-checking both budgets (~$1.7 Apify is
	// fine; ~6.1k BD records would need BD_POSTS_PER_PROFILE trimmed to ≤5).
	"triggers": {
		// every-other-day at 12:00 UTC → Instagram social cache refresh.
		// every 5 min → Bracket Battle engine tick (manual-action pickup within ~5 min /
		//   auto tally + advance / rotate). Cheap: reads config + the active edition and
		//   acts only on a state change.
		// weekly Mon 09:00 UTC → rebuild the NWSL↔ESPN player-headshot map.
		"crons": ["0 12 */2 * *", "*/5 * * * *", "0 9 * * 1"],
	},
}
